#!/bin/sh
# Launch script for {{.App}} backend
# ──────────────────────────────────────────────────────────────────────────────
# Installed to /usr/bin/{{.App}}-backend by nFPM.
# Used by the systemd unit (ExecStart) and for running the backend directly.
#
# Edit the exec line below to match your backend runtime. Examples:
#
#   Java JAR:   exec java ${JAVA_OPTS:--Xmx512m} -jar /opt/{{.App}}/backend/backend.jar "$@"
#   Go binary:  exec /opt/{{.App}}/backend/{{.App}}-backend "$@"
#   Python:     exec /usr/bin/python3 /opt/{{.App}}/backend/main.py "$@"
# ──────────────────────────────────────────────────────────────────────────────

exec /opt/{{.App}}/backend/{{.App}}-backend "$@"
