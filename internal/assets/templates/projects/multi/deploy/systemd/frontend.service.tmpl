[Unit]
Description={{.App}} frontend
# Start after network and after the backend is up.
After=network.target {{.App}}-backend.service

[Service]
User={{.ServiceUser}}
Group={{.ServiceGroup}}
WorkingDirectory=/var/lib/{{.App}}

# Load KEY=VALUE runtime config. The leading '-' allows missing files.
EnvironmentFile=-/etc/{{.App}}/app.env

# Edit deploy/run/{{.App}}-frontend to change the launch command.
ExecStart=/usr/lib/{{.App}}/bin/{{.App}}-frontend

Restart=on-failure
RestartSec=5

# ── Security hardening ─────────────────────────────────────────────────────────
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/{{.App}} /var/log/{{.App}}

[Install]
WantedBy=multi-user.target
