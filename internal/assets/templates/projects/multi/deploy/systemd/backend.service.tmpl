[Unit]
Description={{.App}} backend
# Ensure the network is available before starting.
After=network.target

[Service]
# Run as a dedicated system user (created by postinstall.sh).
User={{.ServiceUser}}
Group={{.ServiceGroup}}
WorkingDirectory=/var/lib/{{.App}}

# Load KEY=VALUE runtime config. The leading '-' allows missing files.
EnvironmentFile=-/etc/{{.App}}/app.env

# Edit deploy/bin/{{.App}}-backend to change the launch command.
ExecStart=/usr/bin/{{.App}}-backend

Restart=on-failure
RestartSec=5

# ── Security hardening ─────────────────────────────────────────────────────────
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/{{.App}} /var/log/{{.App}}

[Install]
WantedBy=multi-user.target
