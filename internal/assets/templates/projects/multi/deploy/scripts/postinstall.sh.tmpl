#!/usr/bin/env bash
# postinstall.sh — runs after the package is installed on the target machine.
set -euo pipefail

# ── Create service user ────────────────────────────────────────────────────────
NOLOGIN=$(command -v nologin 2>/dev/null || echo /usr/sbin/nologin)
id -u {{.ServiceUser}} >/dev/null 2>&1 \
  || useradd --system --home /var/lib/{{.App}} --shell "$NOLOGIN" {{.ServiceUser}}

# ── Set up directories ─────────────────────────────────────────────────────────
mkdir -p /etc/{{.App}} /etc/{{.App}}/hooks /var/lib/{{.App}} /var/log/{{.App}}
chown -R {{.ServiceUser}}:{{.ServiceGroup}} /var/lib/{{.App}} /var/log/{{.App}}

# ── Initialise config ──────────────────────────────────────────────────────────
# Copy every *.example file to its actual counterpart without overwriting
# existing files (preserves manual edits across upgrades).
for example in /etc/{{.App}}/*.example; do
  [ -f "$example" ] || continue
  target="${example%.example}"
  [ -f "$target" ] || cp "$example" "$target"
done

# ── Refresh service manager metadata ───────────────────────────────────────────
# Registration is safe here, but activation is left to the deployment process
# so upgrades can run migrations and health checks before a restart.
if command -v systemctl >/dev/null 2>&1 && [ -d /run/systemd/system ]; then
  systemctl daemon-reload || true
fi

# ── Optional local lifecycle extension ────────────────────────────────────────
# Teams that want restart logic can provide an executable hook at:
#   /etc/{{.App}}/hooks/postinstall.local.sh
if [ -x /etc/{{.App}}/hooks/postinstall.local.sh ]; then
  KT_APP="{{.App}}" \
  KT_KIND="multi-service" \
  KT_SERVICES="{{.App}}-backend,{{.App}}-frontend" \
  KT_SERVICE_USER="{{.ServiceUser}}" \
  KT_SERVICE_GROUP="{{.ServiceGroup}}" \
    /etc/{{.App}}/hooks/postinstall.local.sh "$@"
fi
