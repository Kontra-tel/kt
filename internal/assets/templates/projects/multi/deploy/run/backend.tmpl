#!/bin/sh
# Service runner for {{.App}} backend
# ──────────────────────────────────────────────────────────────────────────────
# This script is packaged for the service manager. Edit the exec line below to
# match your backend runtime.
#
#   Java JAR:   exec java ${JAVA_OPTS:--Xmx512m} -jar /usr/lib/{{.App}}/backend/backend.jar "$@"
#   Go binary:  exec /usr/lib/{{.App}}/backend/{{.App}}-backend "$@"
#   Python:     exec /usr/bin/python3 /usr/lib/{{.App}}/backend/main.py "$@"
# ──────────────────────────────────────────────────────────────────────────────

exec /usr/lib/{{.App}}/backend/{{.App}}-backend "$@"
