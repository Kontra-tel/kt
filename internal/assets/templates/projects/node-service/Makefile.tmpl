APP := {{.App}}
SERVICE_NAME := {{.App}}
VERSION := $(shell cat version.txt)
DOCTOR_TOOLS := git make node npm nfpm systemctl

include .kt/mk/common.mk
include .kt/mk/version.mk
include .kt/mk/config.mk
include .kt/mk/doctor.mk
include .kt/mk/nfpm.mk

.PHONY: test build run install restart logs status

test: ## Run tests
	npm test

build: ## Build Node application (Nuxt 3; adjust for other frameworks)
	npm ci
	npm run build
	rm -rf dist/app && mkdir -p dist/app
	cp -r .output/. dist/app/
	cp package.json dist/app/

run: build ## Run locally
	node dist/app/server/index.mjs

install: local-install ## Install package on this machine

restart: ## Restart service
	sudo systemctl restart $(SERVICE_NAME)

logs: ## Follow logs
	journalctl -u $(SERVICE_NAME) -f

status: ## Service status
	systemctl status $(SERVICE_NAME) --no-pager -l
