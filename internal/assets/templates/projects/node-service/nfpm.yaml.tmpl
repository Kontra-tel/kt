name: {{.App}}
arch: amd64
platform: linux
version: ${VERSION}
section: default
priority: optional
maintainer: {{.Author}}
description: {{.App}} Node service
contents:
  - src: dist/app
    dst: /opt/{{.App}}
  - src: deploy/config/app.env.example
    dst: /etc/{{.App}}/app.env.example
    type: config|noreplace
  - src: deploy/systemd/{{.App}}.service
    dst: /etc/systemd/system/{{.App}}.service
scripts:
  postinstall: deploy/scripts/postinstall.sh
  preremove: deploy/scripts/preremove.sh
