[Unit]
Description={{.App}} frontend
After=network.target {{.App}}-backend.service

[Service]
User={{.ServiceUser}}
Group={{.ServiceGroup}}
WorkingDirectory=/opt/{{.App}}/frontend
# EnvironmentFile loads KEY=VALUE pairs only. For YAML/INI/properties config,
# pass the path via an env var or argument in ExecStart instead.
EnvironmentFile=-/etc/{{.App}}/app.env
# Nuxt 3: /usr/bin/node /opt/{{.App}}/frontend/server/index.mjs
# Express/custom: /usr/bin/node /opt/{{.App}}/frontend/index.js
ExecStart=/usr/bin/node /opt/{{.App}}/frontend/server/index.mjs
Restart=always
RestartSec=10
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/{{.App}}

[Install]
WantedBy=multi-user.target
