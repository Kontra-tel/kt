# Configuration for {{.App}}
# Copy this file to app.env and edit values as needed.
# Run `make config-init` to do this automatically.

# HTTP port the backend service listens on
BACKEND_PORT=8080

# HTTP port the frontend service listens on
FRONTEND_PORT=3000

# JVM tuning flags for the backend
JAVA_OPTS=-Xmx512m

# Runtime environment: production, development
NODE_ENV=production
