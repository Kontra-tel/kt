#!/usr/bin/env bash
set -euo pipefail

if ! command -v systemctl >/dev/null 2>&1 || [ ! -d /run/systemd/system ]; then
  exit 0
fi

old_ifs=$IFS
IFS=','
set -- $KT_SERVICES
IFS=$old_ifs

for service in "$@"; do
  [ -n "$service" ] || continue
  systemctl try-restart "$service" || systemctl start "$service"
done
