#!/bin/sh

print_text() {
cat <<'EOF'
{{.App}}
type: mixed
command: /usr/bin/{{.App}}
service-runner: /usr/lib/{{.App}}/bin/{{.App}}-service
config: /etc/{{.App}}/app.env
hooks: /etc/{{.App}}/hooks/
data: /var/lib/{{.App}}
logs: /var/log/{{.App}}
services:
  - {{.App}}-service
units:
  - {{.App}}-service.service

Use:
  {{.App}}-service --json
  systemctl status {{.App}}-service
  systemctl restart {{.App}}-service
EOF
}

print_json() {
cat <<'EOF'
{
  "app": "{{.App}}",
  "kind": "mixed",
  "command": "/usr/bin/{{.App}}",
  "service_runner": "/usr/lib/{{.App}}/bin/{{.App}}-service",
  "config": "/etc/{{.App}}/app.env",
  "hooks": "/etc/{{.App}}/hooks",
  "data": "/var/lib/{{.App}}",
  "logs": "/var/log/{{.App}}",
  "services": ["{{.App}}-service"],
  "units": ["{{.App}}-service.service"]
}
EOF
}

print_help() {
cat <<'EOF'
Usage: {{.App}}-service [--json]

Print metadata and operator hints for the packaged companion service.
EOF
}

case "${1:-}" in
  "")
    print_text
    ;;
  --json)
    print_json
    ;;
  --help|-h)
    print_help
    ;;
  *)
    echo "unknown argument: $1" >&2
    print_help >&2
    exit 2
    ;;
esac
