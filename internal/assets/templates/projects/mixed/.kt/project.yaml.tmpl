# Project contract used by kt, Make, and packaging.
# Safe to edit after scaffold:
# - app: package/application name used in paths and package metadata
# - kind: project shape; keep this aligned with the template family
# - services: comma-separated packaged service names
# - user/group: service account for service-bearing templates
template: {{.Template}}
app: {{.App}}
kind: mixed
services: {{.App}}-service
user: {{.ServiceUser}}
group: {{.ServiceGroup}}
