# nFPM package manifest — https://nfpm.goreleaser.com/configuration/

name: ${APP}
arch: ${ARCH}
platform: linux
version: ${VERSION}
section: default
priority: optional
maintainer: {{.Author}}
description: ${APP} CLI with companion service

contents:
  - src: dist/app
    dst: /usr/lib/{{.App}}

  - src: deploy/bin/{{.App}}
    dst: /usr/bin/{{.App}}
    file_info:
      mode: 0755

  - src: deploy/bin/{{.App}}-service
    dst: /usr/bin/{{.App}}-service
    file_info:
      mode: 0755

  - src: deploy/run/{{.App}}-service
    dst: /usr/lib/{{.App}}/bin/{{.App}}-service
    file_info:
      mode: 0755

  - src: deploy/config/*.example
    dst: /etc/{{.App}}/
    type: config|noreplace

  - src: deploy/systemd/{{.App}}-service.service
    dst: /usr/lib/systemd/system/{{.App}}-service.service

scripts:
  postinstall: deploy/scripts/postinstall.sh
  preremove: deploy/scripts/preremove.sh
