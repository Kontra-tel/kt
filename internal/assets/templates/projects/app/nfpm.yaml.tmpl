# nFPM package manifest — https://nfpm.goreleaser.com/configuration/
#
# Build packages with:
#   make package          — build for the native package manager and arch
#   make package-deb      — .deb only
#   make package-rpm      — .rpm only
#
# APP, ARCH, and VERSION are injected by nfpm.mk at build time:
#   APP     — from .kt/project.yaml via `kt config get app`
#   ARCH    — host architecture (amd64, arm64, …)
#   VERSION — content of version.txt

# ── Package identity ───────────────────────────────────────────────────────────
name: ${APP}
arch: ${ARCH}
platform: linux
version: ${VERSION}
section: default
priority: optional
maintainer: {{.Author}}
description: ${APP}

# ── Package contents ───────────────────────────────────────────────────────────
contents:
  # Application files — adjust src to match your build output.
  # `make build` should populate dist/app/ before `make package` is called.
  - src: dist/app
    dst: /usr/lib/{{.App}}

  # Additional runtime files (optional) — uncomment to package static assets,
  # SQL migrations, config schemas, or other files your app reads from disk.
  # These are taken directly from the repository, bypassing the build step.
  # - src: resources
  #   dst: /usr/lib/{{.App}}/resources

  # User-facing metadata command — safe to run manually on service hosts.
  - src: deploy/bin/{{.App}}
    dst: /usr/bin/{{.App}}
    file_info:
      mode: 0755

  # Service runner — used by the service manager.
  - src: deploy/run/{{.App}}
    dst: /usr/lib/{{.App}}/bin/{{.App}}
    file_info:
      mode: 0755

  # Runtime config examples — all *.example files are packaged and copied
  # to actual config by postinstall.sh. Non-example files are gitignored.
  - src: deploy/config/*.example
    dst: /etc/{{.App}}/
    type: config|noreplace

  # systemd service unit.
  - src: deploy/systemd/{{.App}}.service
    dst: /usr/lib/systemd/system/{{.App}}.service

scripts:
  postinstall: deploy/scripts/postinstall.sh
  preremove: deploy/scripts/preremove.sh
