[Unit]
Description={{.App}} service
# Ensure the network is available before starting.
# Add other dependencies here, e.g.: After=network.target postgresql.service
After=network.target

[Service]
# Run as a dedicated system user for isolation (created by postinstall.sh).
User={{.ServiceUser}}
Group={{.ServiceGroup}}
WorkingDirectory=/opt/{{.App}}

# Load KEY=VALUE runtime config from /etc/{{.App}}/app.env.
# The leading '-' means the service still starts if the file is absent.
# For structured config (YAML, INI, properties), have your app read the file
# directly and pass its path via an env var or ExecStart argument instead.
EnvironmentFile=-/etc/{{.App}}/app.env

# The launch script at /usr/bin/{{.App}} handles interpreter-specific flags.
# Edit deploy/bin/{{.App}} rather than this file to change the launch command.
ExecStart=/usr/bin/{{.App}}

# Restart automatically if the process exits unexpectedly.
Restart=on-failure
RestartSec=5

# ── Security hardening ─────────────────────────────────────────────────────────
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
# Add every directory your app writes to (logs, uploads, sockets, etc.).
ReadWritePaths=/opt/{{.App}}

[Install]
WantedBy=multi-user.target
