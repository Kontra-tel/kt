#!/bin/sh
# Launch script for {{.App}}
# ──────────────────────────────────────────────────────────────────────────────
# This script is installed to /usr/bin/{{.App}} by nFPM and is used by both
# the systemd service unit (ExecStart) and anyone running the app directly.
#
# Edit the exec line below to match your runtime. Examples:
#
#   Native binary:  exec /usr/lib/{{.App}}/{{.App}} "$@"
#   Java JAR:       exec java ${JAVA_OPTS:--Xmx512m} -jar /usr/lib/{{.App}}/{{.App}}.jar "$@"
#   Node (Nuxt 3):  exec /usr/bin/node /usr/lib/{{.App}}/server/index.mjs "$@"
#   Node (Express): exec /usr/bin/node /usr/lib/{{.App}}/index.js "$@"
#   Python:         exec /usr/bin/python3 /usr/lib/{{.App}}/main.py "$@"
# ──────────────────────────────────────────────────────────────────────────────

exec /usr/lib/{{.App}}/{{.App}} "$@"
