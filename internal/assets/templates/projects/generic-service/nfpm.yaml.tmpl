name: ${APP}
arch: ${ARCH}
platform: linux
version: ${VERSION}
section: default
priority: optional
maintainer: {{.Author}}
description: ${APP} service
contents:
  - src: dist/app
    dst: /opt/${APP}
  - src: deploy/config/*.example
    dst: /etc/${APP}/
    type: config|noreplace
  - src: deploy/systemd/${APP}.service
    dst: /etc/systemd/system/${APP}.service
scripts:
  postinstall: deploy/scripts/postinstall.sh
  preremove: deploy/scripts/preremove.sh
overrides:
  rpm:
    group: Applications/Internet
